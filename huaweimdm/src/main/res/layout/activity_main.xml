<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context="com.mobilewise.mobileware.MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:id="@+id/bt_disopenadmin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="静默开启设备管理器"
            android:textColor="@color/colorPrimaryDark" />

        <Button
            android:id="@+id/bt_closeadmin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="解除设备管理器"
            android:textColor="@color/colorPrimaryDark" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:id="@+id/bt_disbuluetooth"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="禁用蓝牙"
            android:textColor="@color/colorPrimaryDark" />

        <Button
            android:id="@+id/bt_buluetooth"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="启用蓝牙"
            android:textColor="@color/colorPrimaryDark" />
    </LinearLayout>

</LinearLayout>
